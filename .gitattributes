# Auto-detect text files and normalize line endings to LF in repository
* text=auto eol=lf

# Windows batch files use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line-ending conversion
*.docx binary
*.xlsx binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.pdf  binary
*.ico  binary
